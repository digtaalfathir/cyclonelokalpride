    },
    {
      "id": "n-connect",
      "type": "workflowNode",
      "position": { "x": 300, "y": 110 },
      "data": {
        "nodeType": "dbConnect",
        "label": "Connect DB",
        "connectionName": "mainDb",
        "databaseType": "sqlite",
        "databasePath": "./test-output/demo.db",
        "status": ""
      }
    },
    {
      "id": "n-seed",
      "type": "workflowNode",
      "position": { "x": 300, "y": 190 },
      "data": {
        "nodeType": "dbExecute",
        "label": "Seed VIN Queue",
        "connectionName": "mainDb",
        "sql": "CREATE TABLE IF NOT EXISTS vin_queue (id INTEGER PRIMARY KEY, vin TEXT, status TEXT DEFAULT 'PENDING');\nINSERT OR IGNORE INTO vin_queue VALUES (1,'VIN-A001','PENDING');\nINSERT OR IGNORE INTO vin_queue VALUES (2,'VIN-A002','PENDING');\nINSERT OR IGNORE INTO vin_queue VALUES (3,'VIN-B001','PENDING');",
        "status": ""
      }
    },
    {
      "id": "n-query",
      "type": "workflowNode",
      "position": { "x": 300, "y": 270 },
      "data": {
        "nodeType": "dbQuery",
        "label": "Query VIN Queue",
        "connectionName": "mainDb",
        "sql": "SELECT * FROM vin_queue WHERE status = 'PENDING'",
        "outputVariable": "vinList",
        "status": ""
      }
    },
    {
      "id": "n-foreach",
      "type": "workflowNode",
      "position": { "x": 300, "y": 350 },
      "data": {
        "nodeType": "forEachNode",
        "label": "For Each VIN",
        "collection": "{{vinList}}",
        "itemVariable": "row",
        "status": ""
      }
    },
    {
      "id": "n-log-vin",
      "type": "workflowNode",
      "position": { "x": 540, "y": 350 },
      "data": {
        "nodeType": "logMessage",
        "label": "Log VIN",
        "message": "Processing ID={{row.id}} VIN={{row.vin}} Status={{row.status}}",
        "level": "INFO",
        "status": ""
      }
    },
    {
      "id": "n-disconnect",
      "type": "workflowNode",
      "position": { "x": 300, "y": 440 },
      "data": {
        "nodeType": "dbDisconnect",
        "label": "Disconnect DB",
        "connectionName": "mainDb",
        "status": ""
      }
    },
    {
      "id": "n-end",
      "type": "workflowNode",
      "position": { "x": 300, "y": 520 },
      "data": { "nodeType": "end", "label": "End", "autoCloseBrowser": false, "restoreWindow": true, "status": "" }
    }
